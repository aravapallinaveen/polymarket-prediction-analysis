# Polymarket
POLYMARKET_API_BASE=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com

# AWS
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
S3_BUCKET_RAW=polymarket-raw-data
S3_BUCKET_PROCESSED=polymarket-processed

# RDS PostgreSQL
RDS_HOST=your-rds-endpoint.amazonaws.com
RDS_PORT=5432
RDS_DB=polymarket_analysis
RDS_USER=admin
RDS_PASSWORD=your_password

# Reddit
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=polymarket-analyzer/1.0

# Google Trends
GOOGLE_TRENDS_TIMEZONE=360

# NLP
HF_MODEL_NAME=nlptown/bert-base-multilingual-uncased-sentiment
SPACY_MODEL=en_core_web_sm

# API
API_HOST=0.0.0.0
API_PORT=5000
FLASK_ENV=development
